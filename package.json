{
  "name": "backend-setup",
  "version": "1.0.0",
  "description": "a backend boiler plate for smaller projects",
  "main": "index.js",
  "scripts": {
    "build": "rm -rf ./dist && tsc --build tsconfig.prod.json && tsc-alias",
    "start": "node ./dist",
    "start:dev": "nodemon --config nodemon.json",
    "status": "npx prisma migrate status",
    "prisma:studio": "prisma studio",
    "prisma:migrate": "prisma migrate dev",
    "prisma:reset": "prisma migrate reset --force && ts-node --transpile-only prisma/seed.ts",
    "prisma:seed": "ts-node --transpile-only prisma/seed.ts",
    "prisma:generate": "npx prisma generate",
    "test:repositories": "ts-node --transpile-only src/core/examples/test-repository-pattern.ts"
  },
  "author": "Joseph Adeoluwa O.",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.14.0",
    "awilix": "^12.0.5",
    "awilix-express": "^9.0.2",
    "axios": "^1.11.0",
    "bcrypt": "^6.0.0",
    "chalk": "^5.6.0",
    "command-line-args": "^6.0.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-async-errors": "^3.1.1",
    "express-useragent": "^1.0.15",
    "fast-glob": "^3.3.3",
    "google-auth-library": "^10.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "nodemailer": "^7.0.5",
    "pg": "^8.16.3",
    "pino": "^9.9.0",
    "pino-pretty": "^13.1.1",
    "postgres": "^3.4.7",
    "prisma": "^6.14.0",
    "twilio": "^5.8.0",
    "validator": "^13.15.15",
    "winston": "^3.17.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/command-line-args": "^5.2.3",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-useragent": "^1.0.5",
    "@types/helmet": "^4.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/nodemailer": "^7.0.1",
    "@types/validator": "^13.15.3",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.8.1",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2"
  }
}
